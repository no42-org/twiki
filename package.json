{
  "name": "twiki",
  "version": "0.1.0",
  "description": "Autonomous Dependabot/Security PR manager: merges green PRs within policy, batch-cuts patch releases, reports to chat. Safe by construction.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "twiki": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "license": "MIT",
  "author": "Ronny Trommer <ronny@no42.org>",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "^22.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
